APP_NAME="Keuangan Keluarga"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://your-app.vercel.app

LOG_CHANNEL=stderr
LOG_LEVEL=info

# MySQL Database Configuration (e.g. PlanetScale, TiDB, Aiven, Railway, CleverCloud, Supabase MySQL)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=keuangan_keluarga
DB_USERNAME=root
DB_PASSWORD=

# Session and Cache (database driver: Vercel's filesystem is read-only/ephemeral
# per invocation, so "file" sessions get randomly logged out. MySQL is shared
# across every serverless invocation, so it's the only reliable option here.)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database

# Uploaded files (avatars) do NOT survive on Vercel with the local "public" disk
# (filesystem is wiped between invocations). For production, set up a free
# S3-compatible bucket (e.g. Cloudflare R2) and switch this to "s3", filling in
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_DEFAULT_REGION / AWS_BUCKET /
# AWS_ENDPOINT / AWS_USE_PATH_STYLE_ENDPOINT=true below. "public" is fine for
# local development only.
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
